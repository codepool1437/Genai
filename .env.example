# LLM API Key (Get from https://console.groq.com/keys)
GROQ_API_KEY="your_groq_api_key_here"

# Vector DB API Key (Get from https://app.pinecone.io/)
PINECONE_API_KEY="your_pinecone_api_key_here"

# Your Pinecone Index Name (We will use this later when creating the index)
PINECONE_INDEX_NAME="career-guidance"

# HuggingFace Embeddings Model (Using BGE embeddings)
EMBEDDING_MODEL_NAME="BAAI/bge-base-en-v1.5"