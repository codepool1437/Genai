# Backend environment variables
# Copy this file to .env and fill in your values. Never commit .env.

# --- Application ---
APP_ENV=development
SECRET_KEY=change_this_to_a_random_secret_key

# --- Database ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/career_roadmap

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Ollama (local LLM) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# --- Embeddings ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./chroma_db

# --- Langfuse (LLM monitoring) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# --- JWT ---
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Groq (cloud LLM — replaces Ollama) ---
# Get free API keys at https://console.groq.com
# Add multiple keys to rotate and avoid rate limits
GROQ_API_KEY_1=gsk_your_first_key_here
GROQ_API_KEY_2=gsk_your_second_key_here
GROQ_API_KEY_3=gsk_your_third_key_here